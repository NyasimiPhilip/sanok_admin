# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-generate-a-new-one
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,78.111.67.161
DJANGO_TIMEZONE=Africa/Nairobi

# Database Configuration (PostgreSQL)
USE_POSTGRES=True
POSTGRES_DB=sanok_admin_db
POSTGRES_USER=sanok_admin
POSTGRES_PASSWORD=your-secure-database-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Timezone Options (choose based on your primary location):
# Kenya: Africa/Nairobi (default)
# Uganda: Africa/Kampala
# Zambia: Africa/Lusaka
# South Africa: Africa/Johannesburg

# For local development, you can use SQLite:
# USE_POSTGRES=False
# DJANGO_DEBUG=True
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
